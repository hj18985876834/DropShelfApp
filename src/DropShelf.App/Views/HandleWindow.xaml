<Window x:Class="DropShelf.App.Views.HandleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DropShelf Handle"
        Width="36"
        Height="132"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="HandleButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfacePressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Button x:Name="HandleButton"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Style="{StaticResource HandleButtonStyle}"
            ToolTip="Show or hide DropShelf"
            AllowDrop="True"
            Click="HandleButton_OnClick"
            DragOver="HandleButton_OnDragOver"
            Drop="HandleButton_OnDrop"
            MouseEnter="HandleButton_OnMouseEnter"
            MouseLeave="HandleButton_OnMouseLeave"
            PreviewMouseLeftButtonDown="HandleButton_OnPreviewMouseLeftButtonDown"
            PreviewMouseMove="HandleButton_OnPreviewMouseMove"
            PreviewMouseLeftButtonUp="HandleButton_OnPreviewMouseLeftButtonUp">
        <StackPanel x:Name="HandleContent">
            <TextBlock Text="D"
                       FontSize="15"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="S"
                       FontSize="15"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Button>
</Window>
