<Window x:Class="DropShelf.App.Views.HandleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DropShelf Handle"
        Width="36"
        Height="132"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="HandleButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="HandleChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10"
                                                  Direction="270"
                                                  Opacity="0.13"
                                                  ShadowDepth="2"
                                                  Color="#000000" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="DropAccepted">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                                <Setter TargetName="HandleChrome" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfacePressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Button x:Name="HandleButton"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Style="{StaticResource HandleButtonStyle}"
            ToolTip="{Binding HandleTooltip}"
            AllowDrop="True"
            Click="HandleButton_OnClick"
            DragOver="HandleButton_OnDragOver"
            DragLeave="HandleButton_OnDragLeave"
            Drop="HandleButton_OnDrop"
            MouseEnter="HandleButton_OnMouseEnter"
            MouseLeave="HandleButton_OnMouseLeave"
            PreviewMouseLeftButtonDown="HandleButton_OnPreviewMouseLeftButtonDown"
            PreviewMouseMove="HandleButton_OnPreviewMouseMove"
            PreviewMouseLeftButtonUp="HandleButton_OnPreviewMouseLeftButtonUp">
        <StackPanel x:Name="HandleContent"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0">
            <TextBlock Text="&#xE8A5;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="17"
                       HorizontalAlignment="Center"
                       ToolTip="DropShelf" />
            <Border Width="18"
                    Height="2"
                    Margin="0,7,0,0"
                    Background="{DynamicResource DropShelfAccentBrush}"
                    CornerRadius="1"
                    Opacity="0.78" />
        </StackPanel>
    </Button>
</Window>
