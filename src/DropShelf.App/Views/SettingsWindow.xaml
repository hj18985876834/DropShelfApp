<Window x:Class="DropShelf.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="460"
        Height="680"
        ResizeMode="NoResize"
        Background="{DynamicResource DropShelfWindowBackground}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SettingsButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfacePressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SettingsButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource DropShelfAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource DropShelfMutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="SettingsComboStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="6,3" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="InfoTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InfoRowStyle" TargetType="{x:Type StackPanel}">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>

    <Border Margin="18"
            Padding="18"
            Background="{DynamicResource DropShelfPanelBackground}"
            BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Width="32"
                    Height="32"
                    Background="{DynamicResource DropShelfSurfaceBrush}"
                    BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="7">
                <TextBlock Text="&#xE713;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="15"
                           Foreground="{DynamicResource DropShelfAccentBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding HeaderTitle}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DropShelfTextBrush}" />
                <TextBlock Text="{Binding AppName}"
                           FontSize="12"
                           Foreground="{DynamicResource DropShelfMutedTextBrush}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding PreferencesTitle}" Style="{StaticResource SectionTitleStyle}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="{Binding ShelfPositionLabel}" Style="{StaticResource FieldLabelStyle}" />
                        <Button Content="{Binding ResetDockPositionText}"
                                Command="{Binding ResetDockPositionCommand}"
                                Margin="0,0,0,12"
                                Style="{StaticResource SettingsButtonStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="{Binding ThemeLabel}" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding ThemeModeOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding ThemeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource SettingsComboStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="{Binding DensityLabel}" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding DensityModeOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding DensityMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource SettingsComboStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="{Binding LanguageLabel}" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding LanguageModeOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding LanguageMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource SettingsComboStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Text="{Binding AutoUpdateCheckLabel}" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding AutoUpdateCheckModeOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding AutoUpdateCheckMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource SettingsComboStyle}" />
                    </StackPanel>

                    <CheckBox Grid.Row="3"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              Margin="0,8,0,0"
                              Content="{Binding StartWithWindowsText}"
                              Foreground="{DynamicResource DropShelfTextBrush}"
                              IsChecked="{Binding StartWithWindows, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Border Margin="0,18,0,0"
                        Padding="14"
                        Background="{DynamicResource DropShelfSurfaceBrush}"
                        BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="{Binding AboutTitle}" Style="{StaticResource SectionTitleStyle}" />

                        <StackPanel Style="{StaticResource InfoRowStyle}">
                            <TextBlock Text="{Binding SoftwareLabel}" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="{Binding AppName}" Style="{StaticResource InfoTextStyle}" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource InfoRowStyle}">
                            <TextBlock Text="{Binding IntroductionLabel}" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="{Binding AppDescription}" Style="{StaticResource InfoTextStyle}" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource InfoRowStyle}">
                            <TextBlock Text="{Binding UsageLabel}" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="{Binding UsageGuide}" Style="{StaticResource InfoTextStyle}" />
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding VersionLabel}" Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding Version}" Style="{StaticResource InfoTextStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding DeveloperLabel}" Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding Developer}" Style="{StaticResource InfoTextStyle}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Style="{StaticResource InfoRowStyle}">
                            <TextBlock Text="{Binding UpdatesTitle}" Style="{StaticResource FieldLabelStyle}" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding CheckForUpdatesText}"
                                        Command="{Binding CheckForUpdatesCommand}"
                                        Style="{StaticResource SettingsButtonStyle}"
                                        Height="32"
                                        MinWidth="120"
                                        Margin="0,0,8,0" />
                                <Button Content="{Binding DownloadUpdateText}"
                                        Command="{Binding DownloadUpdateCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="32"
                                        MinWidth="120"
                                        Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                            <Border Margin="0,10,0,0"
                                    Padding="10"
                                    MaxHeight="150"
                                    Background="{DynamicResource DropShelfPanelBackground}"
                                    BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Visibility="{Binding HasUpdateDetails, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="{Binding UpdateDetails}" Style="{StaticResource InfoTextStyle}" />
                                        <TextBlock Text="{Binding UpdateReleaseNotes}"
                                                   Style="{StaticResource InfoTextStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="{Binding ContactLabel}" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="{Binding Contact}" Style="{StaticResource InfoTextStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="{Binding ApplyText}"
                        Command="{Binding ApplyCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="32"
                        MinWidth="80"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />
                <Button Content="{Binding CloseText}"
                        Style="{StaticResource SettingsButtonStyle}"
                        Height="32"
                        MinWidth="80"
                        VerticalAlignment="Center"
                        Click="CloseButton_OnClick" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       Visibility="{Binding HasStatus, Converter={StaticResource BooleanToVisibilityConverter}}"
                       TextWrapping="Wrap"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Foreground" Value="{DynamicResource DropShelfMutedTextBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource DropShelfErrorTextBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DockPanel>
    </Grid>
    </Border>
</Window>
