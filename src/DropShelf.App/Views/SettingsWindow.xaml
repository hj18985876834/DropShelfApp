<Window x:Class="DropShelf.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DropShelf Settings"
        Width="420"
        Height="360"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Settings"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Margin="0,0,0,16" />
            <TextBlock Text="Dock edge, theme, density, and startup settings will be configured here."
                       TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
