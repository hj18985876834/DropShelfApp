<Window x:Class="DropShelf.App.Views.ShelfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DropShelf.App.Converters"
        xmlns:models="clr-namespace:DropShelf.App.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DropShelf"
        Width="360"
        Height="520"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ImagePathConverter x:Key="ImagePathConverter" />

        <Style x:Key="HandleButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8,0,0,8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfacePressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="Padding" Value="10,4" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource DropShelfPanelBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ShelfListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ShelfItemTemplate">
            <Border x:Name="Card"
                    Margin="{DynamicResource DropShelfCardMargin}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Cursor="Hand"
                    Padding="{DynamicResource DropShelfCardPadding}"
                    PreviewMouseMove="ShelfItem_OnPreviewMouseMove"
                    MouseLeftButtonDown="ShelfItem_OnMouseLeftButtonDown"
                    MouseLeftButtonUp="ShelfItem_OnMouseLeftButtonUp"
                    SnapsToDevicePixels="True"
                    ToolTip="Drag to copy out">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource DropShelfCardBorderBrush}" />
                        <Setter Property="MinHeight" Value="82" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfWarningTextBrush}" />
                                <Setter Property="Background" Value="{DynamicResource DropShelfWarningBackgroundBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="136" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Grid.Column="0"
                          Width="38"
                          Height="38"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top">
                        <Border Background="{DynamicResource DropShelfSubtleBrush}"
                                BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasImagePreview}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding TypeLabel}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DropShelfTextBrush}" />
                        </Border>

                        <Border Background="{DynamicResource DropShelfSubtleBrush}"
                                BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                ClipToBounds="True">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasImagePreview}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Image Source="{Binding ImagePreviewPath, Converter={StaticResource ImagePathConverter}}"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="{DynamicResource DropShelfTitleFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DropShelfTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding DisplayName}" />
                        <TextBlock Text="{Binding PreviewText}"
                                   Margin="0,4,0,0"
                                   FontSize="{DynamicResource DropShelfBodyFontSize}"
                                   Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding PreviewText}" />
                        <TextBlock Text="Missing"
                                   Margin="0,4,0,0"
                                   FontSize="{DynamicResource DropShelfBodyFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DropShelfErrorTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,4,0,0"
                                   FontSize="{DynamicResource DropShelfBodyFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DropShelfWarningTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding StatusMessage}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="{x:Type StackPanel}">
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                        <Setter Property="Opacity" Value="1" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                        <Setter Property="Opacity" Value="1" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Content="C"
                                Command="{Binding CopyCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Copy"
                                Click="CardActionButton_OnClick" />
                        <Button Content="O"
                                Command="{Binding OpenCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Open"
                                Click="CardActionButton_OnClick" />
                        <Button Content="R"
                                Command="{Binding RevealCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Reveal in Explorer"
                                Click="CardActionButton_OnClick" />
                        <Button Content="X"
                                Command="{Binding RemoveCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Remove"
                                Click="CardActionButton_OnClick" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,10,0,0"
                            Padding="10,8"
                            Background="{DynamicResource DropShelfPanelBackground}"
                            BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            ClipToBounds="True">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding HasExpandedContent}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ScrollViewer MaxHeight="164"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding ExpandedContent}"
                                       FontSize="{DynamicResource DropShelfBodyFontSize}"
                                       Foreground="{DynamicResource DropShelfTextBrush}"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid
          AllowDrop="True"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          DragOver="ShelfHost_OnDragOver"
          DragLeave="ShelfHost_OnDragLeave"
          Drop="ShelfHost_OnDrop"
          MouseEnter="ShelfHost_OnMouseEnter"
          MouseLeave="ShelfHost_OnMouseLeave">
        <Border x:Name="PanelHost"
                Margin="0"
                Opacity="0"
                Padding="{DynamicResource DropShelfPanelPadding}"
                Background="{DynamicResource DropShelfPanelBackground}"
                BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="10,0,0,10">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PanelSlideTransform" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="DropShelf"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource DropShelfTextBrush}"
                               VerticalAlignment="Center" />
                </DockPanel>

                <Border x:Name="DropZone"
                        Grid.Row="1"
                        AllowDrop="True"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        DragOver="DropZone_OnDragOver"
                        DragLeave="DropZone_OnDragLeave"
                        Drop="DropZone_OnDrop">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDragOverAccepted}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDragOverUnsupported}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DropShelfWarningBackgroundBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource DropShelfWarningTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Width="240"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Drop files, text, or images here"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DropShelfTextBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ListBox ItemsSource="{Binding Items}"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                 ItemTemplate="{StaticResource ShelfItemTemplate}"
                                 ItemContainerStyle="{StaticResource ShelfListBoxItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.Style>
                                <Style TargetType="{x:Type ListBox}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
