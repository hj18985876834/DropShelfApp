<Window x:Class="DropShelf.App.Views.ShelfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DropShelf.App.Converters"
        xmlns:models="clr-namespace:DropShelf.App.Models"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="EdgeTuck"
        Width="360"
        Height="520"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewMouseLeftButtonUp="ShelfWindow_OnPreviewMouseLeftButtonUp">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ImagePathConverter x:Key="ImagePathConverter" />

        <Style x:Key="HeaderButtonStyle" TargetType="{x:Type primitives:ButtonBase}">
            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="{DynamicResource DropShelfHeaderButtonFontSize}" />
            <Setter Property="Width" Value="{DynamicResource DropShelfHeaderButtonSize}" />
            <Setter Property="Height" Value="{DynamicResource DropShelfHeaderButtonSize}" />
            <Setter Property="Margin" Value="{DynamicResource DropShelfHeaderButtonMargin}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:ButtonBase}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfacePressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderToggleButtonStyle"
               TargetType="{x:Type ToggleButton}"
               BasedOn="{StaticResource HeaderButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource DropShelfAccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource DropShelfPanelBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfacePressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ManagementButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{DynamicResource DropShelfBodyFontSize}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfacePressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="FontSize" Value="{DynamicResource DropShelfBodyFontSize}" />
            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="FontSize" Value="{DynamicResource DropShelfBodyFontSize}" />
            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
        </Style>

        <Style x:Key="ShelfListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Panel.ZIndex" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReordering}" Value="True">
                    <Setter Property="Panel.ZIndex" Value="100" />
                    <Setter Property="Opacity" Value="0.35" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ShelfItemTemplate">
            <Border x:Name="Card"
                    Margin="{DynamicResource DropShelfCardMargin}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Cursor="Hand"
                    Padding="{DynamicResource DropShelfCardPadding}"
                    PreviewMouseMove="ShelfItem_OnPreviewMouseMove"
                    PreviewMouseLeftButtonDown="ShelfItem_OnPreviewMouseLeftButtonDown"
                    MouseLeftButtonUp="ShelfItem_OnMouseLeftButtonUp"
                    RenderTransformOrigin="0.5,0.5"
                    SnapsToDevicePixels="True"
                    ToolTip="{Binding DragOutTooltip}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="0"
                                      Direction="270"
                                      Opacity="0"
                                      ShadowDepth="0"
                                      Color="#000000" />
                </Border.Effect>
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <TranslateTransform X="0" Y="0" />
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                 Opened="CardContextMenu_OnOpened"
                                 Closed="CardContextMenu_OnClosed">
                        <MenuItem Header="{Binding ContextCopyText}"
                                  Command="{Binding CopyCommand}" />
                        <MenuItem Header="{Binding ContextOpenText}"
                                  Command="{Binding OpenCommand}" />
                        <MenuItem Header="{Binding ContextRevealText}"
                                  Command="{Binding RevealCommand}" />
                        <MenuItem Header="{Binding ContextRelinkText}"
                                  Command="{Binding RelinkCommand}"
                                  Visibility="{Binding CanRelink, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Separator />
                        <MenuItem Header="{Binding ContextRemoveText}"
                                  Command="{Binding RemoveCommand}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource DropShelfCardBorderBrush}" />
                        <Setter Property="MinHeight" Value="{DynamicResource DropShelfCardMinHeight}" />
                        <Setter Property="Panel.ZIndex" Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBatchSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfWarningTextBrush}" />
                                <Setter Property="Background" Value="{DynamicResource DropShelfWarningBackgroundBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfWarningTextBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsReordering}" Value="True">
                                <Setter Property="Panel.ZIndex" Value="20" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                                <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                            </DataTrigger>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0"
                                                         To="1"
                                                         Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{DynamicResource DropShelfTypeBadgeColumnWidth}" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="ReorderHandle"
                          Grid.Row="0"
                          Grid.Column="0"
                          Width="{DynamicResource DropShelfTypeBadgeSize}"
                          Height="{DynamicResource DropShelfTypeBadgeSize}"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Cursor="SizeAll"
                          ToolTip="{Binding ReorderHandleTooltip}"
                          MouseLeftButtonDown="ReorderHandle_OnMouseLeftButtonDown"
                          PreviewMouseMove="ReorderHandle_OnPreviewMouseMove"
                          MouseLeftButtonUp="ReorderHandle_OnMouseLeftButtonUp"
                          LostMouseCapture="ReorderHandle_OnLostMouseCapture">
                        <Border Background="{DynamicResource DropShelfSubtleBrush}"
                                BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasImagePreview}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding TypeIcon}"
                                       FontFamily="Segoe MDL2 Assets"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="{DynamicResource DropShelfTypeIconFontSize}"
                                       Foreground="{DynamicResource DropShelfAccentBrush}"
                                       ToolTip="{Binding TypeDisplayName}" />
                        </Border>

                        <Border Background="{DynamicResource DropShelfSubtleBrush}"
                                BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                ClipToBounds="True">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasImagePreview}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Image Source="{Binding ImagePreviewPath, Converter={StaticResource ImagePathConverter}}"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="0,0,0,0">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="{DynamicResource DropShelfTitleFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DropShelfTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding DisplayName}" />
                        <TextBlock Text="{Binding PreviewText}"
                                   Margin="{DynamicResource DropShelfCardTextGap}"
                                   FontSize="{DynamicResource DropShelfBodyFontSize}"
                                   Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                   ToolTip="{Binding PreviewTextTooltip}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    <Setter Property="TextWrapping" Value="NoWrap" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpandedContentVisible}" Value="True">
                                            <Setter Property="TextTrimming" Value="None" />
                                            <Setter Property="TextWrapping" Value="Wrap" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding MetadataText}"
                                   Margin="{DynamicResource DropShelfCardTextGap}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding MetadataText}" />
                        <TextBlock Text="{Binding MissingSourceText}"
                                   Margin="{DynamicResource DropShelfCardTextGap}"
                                   FontSize="{DynamicResource DropShelfBodyFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DropShelfErrorTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding DuplicateSourceText}"
                                   Margin="{DynamicResource DropShelfCardTextGap}"
                                   FontSize="{DynamicResource DropShelfBodyFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DropShelfWarningTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="{DynamicResource DropShelfCardTextGap}"
                                   FontSize="{DynamicResource DropShelfBodyFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DropShelfWarningTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding StatusMessage}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid
          AllowDrop="True"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          DragOver="ShelfHost_OnDragOver"
          DragLeave="ShelfHost_OnDragLeave"
          Drop="ShelfHost_OnDrop"
          MouseEnter="ShelfHost_OnMouseEnter"
          MouseLeave="ShelfHost_OnMouseLeave">
        <Border x:Name="PanelHost"
                Margin="0"
                Opacity="0"
                Padding="{DynamicResource DropShelfPanelPadding}"
                Background="{DynamicResource DropShelfPanelBackground}"
                BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="10,0,0,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  Direction="270"
                                  Opacity="0.16"
                                  ShadowDepth="4"
                                  Color="#000000" />
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="PanelSlideTransform" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="30"
                                Height="30"
                                Background="{DynamicResource DropShelfSurfaceBrush}"
                                BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7">
                            <TextBlock Text="&#xE8A5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Foreground="{DynamicResource DropShelfAccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="9,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="EdgeTuck"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DropShelfTextBrush}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ItemCount, Mode=OneWay}"
                                           FontSize="{DynamicResource DropShelfBodyFontSize}"
                                           Foreground="{DynamicResource DropShelfMutedTextBrush}" />
                                <TextBlock Text="{Binding ItemCountSuffix}"
                                           FontSize="{DynamicResource DropShelfBodyFontSize}"
                                           Foreground="{DynamicResource DropShelfMutedTextBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <ToggleButton Content="&#xE718;"
                                      IsChecked="{Binding IsShelfPinned, Mode=TwoWay}"
                                      Style="{StaticResource HeaderToggleButtonStyle}"
                                      ToolTip="{Binding PinShelfTooltip}" />
                        <Button Content="&#xE74D;"
                                Command="{Binding ClearAllCommand}"
                                Style="{StaticResource HeaderButtonStyle}"
                                ToolTip="{Binding ClearAllTooltip}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{Binding ClearInvalidTooltip}"
                                              Command="{Binding ClearInvalidCommand}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Content="&#xE713;"
                                Command="{Binding OpenSettingsCommand}"
                                Style="{StaticResource HeaderButtonStyle}"
                                ToolTip="{Binding SettingsTooltip}" />
                        <Button Content="&#xE70D;"
                                Command="{Binding HideShelfCommand}"
                                Style="{StaticResource HeaderButtonStyle}"
                                ToolTip="{Binding CollapseTooltip}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding FilterLabel}"
                                   Margin="0,0,6,0"
                                   FontSize="{DynamicResource DropShelfBodyFontSize}"
                                   Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                   VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding FilterModeOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding ActiveFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource FilterComboStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                        <TextBlock Text="{Binding SearchPlaceholder}"
                                   Margin="0,0,6,0"
                                   FontSize="{DynamicResource DropShelfBodyFontSize}"
                                   Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchBoxStyle}" />
                    </StackPanel>
                </Grid>

                <Border x:Name="DropZone"
                        Grid.Row="2"
                        AllowDrop="True"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="{DynamicResource DropShelfDropZonePadding}"
                        DragOver="DropZone_OnDragOver"
                        DragLeave="DropZone_OnDragLeave"
                        Drop="DropZone_OnDrop">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfPanelBorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDragOverAccepted}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DropShelfSurfaceHoverBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDragOverUnsupported}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DropShelfWarningBackgroundBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource DropShelfWarningTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Margin="4"
                              Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="250">
                                <Border Width="52"
                                        Height="52"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource DropShelfSubtleBrush}"
                                        BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <TextBlock Text="&#xE8B6;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="25"
                                               Foreground="{DynamicResource DropShelfAccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding EmptyTitle}"
                                           Margin="0,14,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DropShelfTextBrush}"
                                           TextAlignment="Center" />
                                <TextBlock Text="{Binding EmptyDescription}"
                                           Margin="0,6,0,0"
                                           FontSize="{DynamicResource DropShelfBodyFontSize}"
                                           Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <UniformGrid Columns="3"
                                             Margin="0,16,0,0">
                                    <Border Margin="3,0"
                                            Padding="8,5"
                                            Background="{DynamicResource DropShelfPanelBackground}"
                                            BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5">
                                        <TextBlock Text="{Binding EmptyFileChip}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                                   TextAlignment="Center" />
                                    </Border>
                                    <Border Margin="3,0"
                                            Padding="8,5"
                                            Background="{DynamicResource DropShelfPanelBackground}"
                                            BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5">
                                        <TextBlock Text="{Binding EmptyTextChip}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                                   TextAlignment="Center" />
                                    </Border>
                                    <Border Margin="3,0"
                                            Padding="8,5"
                                            Background="{DynamicResource DropShelfPanelBackground}"
                                            BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5">
                                        <TextBlock Text="{Binding EmptyImageChip}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                                   TextAlignment="Center" />
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="ShelfItemsList"
                                 ItemsSource="{Binding VisibleItems}"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                 ItemTemplate="{StaticResource ShelfItemTemplate}"
                                 ItemContainerStyle="{StaticResource ShelfListBoxItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 PreviewMouseWheel="ShelfItemsList_OnPreviewMouseWheel"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 Padding="0"
                                 SnapsToDevicePixels="True">
                            <ListBox.Style>
                                <Style TargetType="{x:Type ListBox}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsNoResults}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                        </ListBox>

                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Margin="4"
                              Visibility="{Binding IsNoResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="250">
                                <Border Width="48"
                                        Height="48"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource DropShelfSubtleBrush}"
                                        BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <TextBlock Text="&#xE71C;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="22"
                                               Foreground="{DynamicResource DropShelfAccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding NoResultsTitle}"
                                           Margin="0,12,0,0"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DropShelfTextBrush}"
                                           TextAlignment="Center" />
                                <TextBlock Text="{Binding NoResultsDescription}"
                                           Margin="0,6,0,0"
                                           FontSize="{DynamicResource DropShelfBodyFontSize}"
                                           Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Border x:Name="DropStateOverlay"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                BorderThickness="2"
                                CornerRadius="8"
                                IsHitTestVisible="False">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="240">
                                <TextBlock x:Name="DropStateIcon"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="28"
                                           TextAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Text" Value="&#xE8B6;" />
                                            <Setter Property="Foreground" Value="{DynamicResource DropShelfAccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDragOverUnsupported}" Value="True">
                                                    <Setter Property="Text" Value="&#xE783;" />
                                                    <Setter Property="Foreground" Value="{DynamicResource DropShelfWarningTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock x:Name="DropStateText"
                                           Text="{Binding DropStateText}"
                                           Margin="0,8,0,0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{DynamicResource DropShelfTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDragOverUnsupported}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource DropShelfWarningTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource DropShelfAccentBrush}" />
                                    <Setter Property="Opacity" Value="0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDragOverAccepted}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                            <Setter Property="Background" Value="#22000000" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDragOverUnsupported}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource DropShelfWarningTextBrush}" />
                                            <Setter Property="Background" Value="#22FFB000" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                MaxWidth="280"
                                Margin="12"
                                Padding="12,9"
                                Background="{DynamicResource DropShelfWarningBackgroundBrush}"
                                BorderBrush="{DynamicResource DropShelfWarningTextBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Panel.ZIndex="30"
                                Visibility="{Binding HasShelfStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding ShelfStatusMessage}"
                                       FontSize="{DynamicResource DropShelfBodyFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DropShelfWarningTextBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Canvas x:Name="ReorderOverlayLayer"
                IsHitTestVisible="False"
                Panel.ZIndex="1000">
            <Border x:Name="ReorderDropIndicator"
                    Visibility="Collapsed"
                    Width="260"
                    Height="3"
                    CornerRadius="1.5"
                    Background="{DynamicResource DropShelfAccentBrush}"
                    Opacity="0.96">
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      Direction="270"
                                      Opacity="0.22"
                                      ShadowDepth="0"
                                      Color="#000000" />
                </Border.Effect>
            </Border>

            <Border x:Name="ReorderPreviewCard"
                    Visibility="Collapsed"
                    Width="260"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="{DynamicResource DropShelfCardPadding}"
                    Background="{DynamicResource DropShelfSurfaceHoverBrush}"
                    BorderBrush="{DynamicResource DropShelfAccentBrush}"
                    RenderTransformOrigin="0.5,0.5"
                    ClipToBounds="True"
                    SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="34"
                                      Direction="270"
                                      Opacity="0.42"
                                      ShadowDepth="14"
                                      Color="#000000" />
                </Border.Effect>
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1.045" ScaleY="1.045" />
                        <TranslateTransform />
                    </TransformGroup>
                </Border.RenderTransform>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{DynamicResource DropShelfTypeBadgeColumnWidth}" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="{DynamicResource DropShelfTypeBadgeSize}"
                            Height="{DynamicResource DropShelfTypeBadgeSize}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="{DynamicResource DropShelfSubtleBrush}"
                            BorderBrush="{DynamicResource DropShelfPanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <TextBlock Text="{Binding TypeIcon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="{DynamicResource DropShelfTypeIconFontSize}"
                                   Foreground="{DynamicResource DropShelfAccentBrush}" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="{DynamicResource DropShelfTitleFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DropShelfTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <TextBlock Text="{Binding PreviewText}"
                                   Margin="{DynamicResource DropShelfCardTextGap}"
                                   FontSize="{DynamicResource DropShelfBodyFontSize}"
                                   Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <TextBlock Text="{Binding MetadataText}"
                                   Margin="{DynamicResource DropShelfCardTextGap}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DropShelfMutedTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </Canvas>

    </Grid>
</Window>
